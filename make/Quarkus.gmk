QUARKUS_HOME ?= $(HOME)/src/quarkus-$(ID)
QUARKUS_VERSION ?= 999-SNAPSHOT
TEST_MODULE ?= main

build-quarkus:
> cd $(QUARKUS_HOME)
> ./mvnw -Dquickly
.PHONY: build-quarkus

test_quarkus_args += -Dnative
test_quarkus_args += -Dnative.surefire.skip
test_quarkus_args += -Dquarkus.native.container-build=false

ifdef CONTAINER
  test_quarkus_args += -Dtest-containers
  test_quarkus_args += -Dstart-containers
endif

ifdef DEBUG
  test_mvn = mvnDebug
else
  test_mvn = ./mvnw
endif

ifdef TRACE
  test_quarkus_args += -Dquarkus.log.min-level=TRACE
  test_quarkus_args += -Dquarkus.log.level=TRACE
endif

quarkus_core_jar = $(QUARKUS_HOME)/core/deployment/target/quarkus-core-deployment-$(QUARKUS_VERSION).jar
$(quarkus_core_jar): $(shell find $(QUARKUS_HOME)/core -type f -name '*.java' | grep -v '/target/' | sed 's: :\\ :g')
$(quarkus_core_jar): $(shell find $(QUARKUS_HOME)/core -type f -name 'pom.xml' | sed 's: :\\ :g')
> cd $(QUARKUS_HOME)
> ./mvnw -DskipTests -f core install
> touch $@

quarkus_extensions_amazon_lambda_jar = $(QUARKUS_HOME)/extensions/amazon-lambda/deployment/target/quarkus-amazon-lambda-deployment-$(QUARKUS_VERSION).jar
$(quarkus_extensions_amazon_lambda_jar): $(shell find $(QUARKUS_HOME)/extensions/amazon-lambda -type f -name '*.java' | grep -v '/target/' | sed 's: :\\ :g')
$(quarkus_extensions_amazon_lambda_jar): $(shell find $(QUARKUS_HOME)/extensions/amazon-lambda -type f -name 'pom.xml' | sed 's: :\\ :g')
> cd $(QUARKUS_HOME)
> ./mvnw -DskipTests -f extensions/amazon-lambda install
> touch $@

