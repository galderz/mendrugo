quarkus: $(quarkus_core_jar)
quarkus: $(quarkus_extensions_amazon_lambda_jar)
quarkus: $(quarkus_extensions_grpc_jar)
quarkus: $(quarkus_extensions_hibernate_orm_jar)
quarkus: $(quarkus_extensions_micrometer_jar)
quarkus: $(quarkus_extensions_netty_jar)
quarkus: $(quarkus_extensions_rest_client_jar)
quarkus: $(quarkus_extensions_rest_client_jaxrs_jar)
quarkus: $(quarkus_extensions_scheduler_jar)
quarkus: $(quarkus_extensions_security_jar)
quarkus: $(quarkus_extensions_spring_web_jar)
quarkus: $(quarkus_extensions_vertx_jar)

test-quarkus: quarkus
> cd $(QUARKUS_HOME)
> $(test_mvn) $(test_quarkus_args) clean install -f integration-tests/$(TEST_MODULE)
.PHONY: test-quarkus
